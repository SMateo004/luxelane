rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // -------------------------------------------------------------------------
    // Helpers — role is stored in /users/{uid}.role in Firestore
    // -------------------------------------------------------------------------

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return request.auth != null && getUserRole() == 'admin';
    }

    function isDriver() {
      return request.auth != null && getUserRole() == 'driver';
    }

    function isRider() {
      return request.auth != null && getUserRole() == 'rider';
    }

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    function onlyUpdating(fields) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(fields);
    }

    // -------------------------------------------------------------------------
    // /users/{uid}
    // -------------------------------------------------------------------------

    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // /driverProfiles/{uid}
    // -------------------------------------------------------------------------

    match /driverProfiles/{uid} {
      allow read:   if isAuthenticated();
      allow create: if isOwner(uid) && isDriver();
      allow update: if (isOwner(uid) && isDriver()) || isAdmin();
      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // /bookings/{bookingId}
    // -------------------------------------------------------------------------

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (
        resource.data.riderId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        (resource.data.status == 'pending' && isDriver()) ||
        isAdmin()
      );

      // Any authenticated user can create a booking for themselves
      allow create: if isAuthenticated() &&
        request.resource.data.riderId == request.auth.uid;

      allow update: if isAdmin() ||
        // Driver accepts a pending booking (self-assign)
        (isAuthenticated() &&
          resource.data.status == 'pending' &&
          request.resource.data.driverId == request.auth.uid &&
          request.resource.data.status == 'confirmed' &&
          onlyUpdating(['driverId', 'status', 'updatedAt'])) ||
        // Driver progresses their assigned booking through statuses
        (isAuthenticated() &&
          resource.data.driverId == request.auth.uid &&
          onlyUpdating(['status', 'updatedAt'])) ||
        // Rider cancels their own booking
        (isAuthenticated() &&
          resource.data.riderId == request.auth.uid &&
          onlyUpdating(['status', 'updatedAt']) &&
          request.resource.data.status == 'cancelled');

      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // /rides/{rideId}
    // -------------------------------------------------------------------------

    match /rides/{rideId} {
      allow read: if isAuthenticated() && (
        resource.data.riderId == request.auth.uid ||
        resource.data.driverId == request.auth.uid ||
        isAdmin()
      );

      allow create: if isAdmin();

      allow update: if isAdmin() || (
        isAuthenticated() &&
        isDriver() &&
        resource.data.driverId == request.auth.uid &&
        onlyUpdating([
          'driverRoute',
          'completedAt',
          'distanceKm',
          'durationMin',
          'riderRating',
          'driverRating'
        ])
      );

      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // /payments/{paymentId}
    // -------------------------------------------------------------------------

    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        resource.data.riderId == request.auth.uid || isAdmin()
      );
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // /vehicles/{vehicleId}
    // -------------------------------------------------------------------------

    match /vehicles/{vehicleId} {
      allow read:   if isAuthenticated();
      allow create: if isAdmin() ||
        (isDriver() && isOwner(request.resource.data.driverId));
      allow update: if isAdmin() || (
        isDriver() &&
        resource.data.driverId == request.auth.uid &&
        onlyUpdating(['isActive', 'color', 'photoUrl'])
      );
      allow delete: if false;
    }

    // -------------------------------------------------------------------------
    // /pricingRules/{ruleId}
    // -------------------------------------------------------------------------

    match /pricingRules/{ruleId} {
      allow read:   if isAuthenticated();
      allow write:  if isAdmin();
    }
  }
}
